# Copy to .env.production and fill in all CHANGE_ME values before deploying.
# NEVER commit .env.production to version control.

# --- PostgreSQL ---
POSTGRES_USER=tryggve
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=tryggve

# --- Backend ---
GEMINI_API_KEY=CHANGE_ME_GEMINI_API_KEY
# Comma-separated list of allowed browser origins (no wildcards in production).
# Example: https://tryggve.example.com
CORS_ORIGINS=https://tryggve.example.com
UVICORN_WORKERS=2

# --- Frontend (baked at build time; leave empty for same-origin /api via nginx) ---
NEXT_PUBLIC_API_BASE_URL=

# --- Edge proxy ---
NGINX_HTTP_PORT=80
